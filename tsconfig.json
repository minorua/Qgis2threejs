{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "strict": false,

    "rootDir": "web/js",
    "outDir": "web/js/types",

    "paths": {
      "three": ["./web/js/lib/three/three.module.js"],
      "three/*": ["./web/js/lib/three/*"]
    }
  },
  "include": [
    "web/js/**/*.js"
  ],
  "exclude": [
    "web/js/lib"
  ]
}
